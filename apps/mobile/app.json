{
  "expo": {
    "name": "KŌDO",
    "slug": "kodo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kodo",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0C0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kodo.app"
    },
    "android": {
      "package": "com.kodo.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D0C0A"
      }
    },
    "plugins": [
      "expo-router",
      ["expo-font", { "fonts": [] }],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C4A064"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
